# ── Database ─────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=postgresql://tokenflow:tokenflow@localhost:5432/tokenflow_db
# Neon (production):
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ── Redis / Arq ───────────────────────────────────────────────────────────────
# Local dev (Redis must be running):
REDIS_URL=redis://localhost:6379/0
# Upstash (production) — use the redis:// or rediss:// URL from your Upstash dashboard:
# REDIS_URL=rediss://default:xxxx@global-xxx.upstash.io:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
DEFAULT_ADMIN_EMAIL=admin@tokenflow.local
DEFAULT_ADMIN_PASSWORD=tokenflow2024

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins:
ALLOWED_ORIGINS=http://localhost:3000
# Production example:
# ALLOWED_ORIGINS=https://tokenflow-ai.vercel.app

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (set in Vercel dashboard, not in this file):
# NEXT_PUBLIC_API_URL=https://tokenflow-api.onrender.com
